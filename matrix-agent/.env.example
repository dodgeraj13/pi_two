# Matrix Agent (Pi) Environment Configuration
# Copy this file to .env in the matrix-agent directory

# Backend server URL
BACKEND_URL=https://your-backend-url
SERVER_URL=https://your-backend-url

# WebSocket URL (auto-derived from BACKEND_URL if not set)
WS_URL=wss://your-backend-url/ws

# API token for authentication (must match backend API_TOKEN)
API_TOKEN=your_secure_api_token_here

# Optional: Directory paths (defaults shown)
MLB_DIR=/home/pi/mlb-led-scoreboard
MUSIC_DIR=/home/pi/rpi-spotify-matrix-display
CLOCK_DIR=/home/pi/matrix-clock
WEATHER_DIR=/home/pi/matrix-weather
PICTURE_DIR=/home/pi/matrix-picture
DRAWING_DIR=/home/pi/matrix-drawing
TEXT_DIR=/home/pi/matrix-text