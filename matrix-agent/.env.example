# Matrix Agent Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend ──────────────────────────────────────────────────────
BACKEND_BASE=https://your-backend-url.onrender.com
WS_URL=wss://your-backend-url.onrender.com/ws

# ── Device identity ───────────────────────────────────────────────
# UUID issued by POST /devices on the backend (see setup.sh)
DEVICE_TOKEN=your-device-uuid-here

# ── Display ───────────────────────────────────────────────────────
# Rotation in degrees: 0, 90, 180, or 270
ROTATION=90

# ── Paths (auto-set by setup.sh, change only if non-standard) ────
HOME_DIR=/home/YOUR_PI_USERNAME
MLB_DIR=/home/YOUR_PI_USERNAME/mlb-led-scoreboard
MUSIC_DIR=/home/YOUR_PI_USERNAME/rpi-spotify-matrix-display
CLOCK_DIR=/home/YOUR_PI_USERNAME/matrix-clock
WEATHER_DIR=/home/YOUR_PI_USERNAME/matrix-weather
PICTURE_DIR=/home/YOUR_PI_USERNAME/matrix-picture
DRAWING_DIR=/home/YOUR_PI_USERNAME/matrix-drawing
TEXT_DIR=/home/YOUR_PI_USERNAME/matrix-text
